@adminBaseUrl = http://localhost:8080


### HRM login via admin auth
POST {{adminBaseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "employeeEmail": "workerTest@test.com",
  "password": "password123!"
}

> {%
    client.global.set("accessToken", response.body.data.accessToken);
    client.global.set("refreshToken", response.body.data.refreshToken);
%}

### worker profile
GET http://localhost:8081/api/v1/hr/workers/me/profile
Authorization: Bearer {{accessToken}}

### worker skills
GET http://localhost:8081/api/v1/hr/workers/me/skills
Authorization: Bearer {{accessToken}}

### worker tier-chart
GET http://localhost:8081/api/v1/hr/workers/me/tier-chart
Authorization: Bearer {{accessToken}}

### worker missions
GET http://localhost:8081/api/v1/hr/workers/me/missions
Authorization: Bearer {{accessToken}}

### worker point-summary
GET http://localhost:8081/api/v1/hr/workers/me/point-summary
Authorization: Bearer {{accessToken}}

### worker point-history
GET http://localhost:8081/api/v1/hr/workers/me/point-history
Authorization: Bearer {{accessToken}}